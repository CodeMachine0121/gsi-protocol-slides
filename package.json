{
  "name": "gsi-protocol-slides",
  "type": "module",
  "private": true,
  "description": "Slidev deck for the GSI-Protocol talk — Spec-Driven Development for AI coding",
  "scripts": {
    "dev": "slidev --open",
    "build": "slidev build",
